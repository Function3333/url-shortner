# Copy to .env and adjust as needed. .env is gitignored — never commit real secrets.
# Every value the app reads is listed here (12-factor; see docs/app-spec.md).

# HTTP port the app listens on.
PORT=3000

# Postgres connection string. Host is localhost for a host-run `npm run dev`
# against `docker compose up -d`; inside a container/k8s it becomes the service
# name (e.g. postgres://postgres:postgres@postgres:5432/shortener).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/shortener

# Redis connection string (redis://host:port).
REDIS_URL=redis://localhost:6379

# Build identity. Injected by the Docker build (ARG BUILD_SHA -> ENV); surfaced
# at GET /version. "dev" is the local default.
BUILD_SHA=dev

# Bad-version reproduction switch for the rollback demo. Set to "fail" to make
# /readyz return 503 even while the process is alive. Leave empty for normal runs.
READY_OVERRIDE=
